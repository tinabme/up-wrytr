# GitHub personal access token (classic or fine-grained)
# Create one at: https://github.com/settings/tokens
# Fine-grained tokens work with no special permissions (just public access)
GITHUB_TOKEN=your_github_token_here

# Optional: Set default tone (professional, casual, silly, empathetic, mixed)
DEFAULT_TONE=mixed

# Optional: Set default channel (slack, email, github)
DEFAULT_CHANNEL=slack

# Optional: Choose model from GitHub Models marketplace
# Options: gpt-4o-mini (default, fast), gpt-4o (smarter), Phi-4, Mistral-large
# Browse all: https://github.com/marketplace/models
LLM_MODEL=gpt-4o-mini
